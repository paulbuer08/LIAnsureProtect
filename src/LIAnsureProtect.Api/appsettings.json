{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Authority": "",
    "Audience": "",
    "RoleClaimType": "roles"
  },
  "Database": {
    "ConnectionPool": {
      "MinimumPoolSize": 0,
      "MaximumPoolSize": 40,
      "ConnectionTimeoutSeconds": 15,
      "CommandTimeoutSeconds": 30,
      "IdleLifetimeSeconds": 300,
      "PruningIntervalSeconds": 10,
      "ConnectionLifetimeSeconds": 3600
    }
  },
  "Notifications": {
    "Realtime": {
      "Enabled": false,
      "RedisConnectionString": "",
      "ChannelPrefix": "liansureprotect-notifications"
    }
  }
}
