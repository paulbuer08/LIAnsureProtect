# Copy to .env.local (gitignored) and fill with your local Auth0/API values.
# Double underscores map to ASP.NET Core configuration sections.
Authentication__Authority=https://dev-yourtenant.us.auth0.com/
Authentication__Audience=https://api.liansureprotect.local
Authentication__RoleClaimType=https://liansureprotect.local/roles

# Optional locally: defaults point to the Docker Compose Mailpit SMTP capture service.
# Production supplies a real relay and credentials through the environment/secrets manager.
# LIANSUREPROTECT_SMTP_HOST=localhost
# LIANSUREPROTECT_SMTP_PORT=1025
# LIANSUREPROTECT_SMTP_FROM=no-reply@liansureprotect.local
# LIANSUREPROTECT_SMTP_TLS=false
# LIANSUREPROTECT_SMTP_USERNAME=
# LIANSUREPROTECT_SMTP_PASSWORD=
