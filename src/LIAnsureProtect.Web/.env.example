# Copy to .env.local (gitignored) and fill with your Auth0 tenant values.
# See docs/guides/running-the-app.md for the full one-time Auth0 setup.
VITE_AUTH0_DOMAIN=dev-yourtenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID
VITE_AUTH0_AUDIENCE=https://api.liansureprotect.local
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/callback
VITE_API_BASE_URL=http://localhost:5223
