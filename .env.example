LIANSUREPROTECT_POSTGRES_IMAGE=pgvector/pgvector:0.8.2-pg16-trixie

# --- M42/M43 optional: AWS services via LocalStack (no AWS account needed) ---
# Start LocalStack (S3 + SNS + SQS):  docker compose --profile aws-local up -d
# Then run the opt-in S3 document round-trip test with these set:
# LIANSUREPROTECT_RUN_S3_TESTS=true
# LIANSUREPROTECT_TEST_S3_SERVICE_URL=http://localhost:4566
# LIANSUREPROTECT_TEST_S3_BUCKET=liansureprotect-evidence-test
# And/or the opt-in SNS->SQS notification round-trip test:
# LIANSUREPROTECT_RUN_SNS_TESTS=true
# LIANSUREPROTECT_TEST_SNS_SERVICE_URL=http://localhost:4566
